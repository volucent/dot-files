{
  "permissions": {
    "allow": [
      "Bash(glab mr diff:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal 'Claude Code' 'Waiting for your response' && printf '\\a'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true
}
