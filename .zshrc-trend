# If you come from bash you might have to change your $PATH.
export PATH=$HOME/bin:$PATH

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time oh-my-zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
# ZSH_THEME="dieter"
# ZSH_THEME="jonathan"
# ZSH_THEME="philips"
# ZSH_THEME="pmcgee"
ZSH_THEME="frisk"

# Set list of themes to pick from when loading at random
# Setting this variable when ZSH_THEME=random will cause zsh to load
# a theme from this variable instead of looking in $ZSH/themes/
# If set to an empty array, this variable will have no effect.
# ZSH_THEME_RANDOM_CANDIDATES=( "robbyrussell" "agnoster" )

# Uncomment the following line to use case-sensitive completion.
# CASE_SENSITIVE="true"

# Uncomment the following line to use hyphen-insensitive completion.
# Case-sensitive completion must be off. _ and - will be interchangeable.
# HYPHEN_INSENSITIVE="true"

# Uncomment one of the following lines to change the auto-update behavior
# zstyle ':omz:update' mode disabled  # disable automatic updates
# zstyle ':omz:update' mode auto      # update automatically without asking
# zstyle ':omz:update' mode reminder  # just remind me to update when it's time

# Uncomment the following line to change how often to auto-update (in days).
# zstyle ':omz:update' frequency 13

# Uncomment the following line if pasting URLs and other text is messed up.
# DISABLE_MAGIC_FUNCTIONS="true"

# Uncomment the following line to disable colors in ls.
# DISABLE_LS_COLORS="true"

# Uncomment the following line to disable auto-setting terminal title.
DISABLE_AUTO_TITLE="true"

# Uncomment the following line to enable command auto-correction.
# ENABLE_CORRECTION="true"

# Uncomment the following line to display red dots whilst waiting for completion.
# You can also set it to another string to have that shown instead of the default red dots.
# e.g. COMPLETION_WAITING_DOTS="%F{yellow}waiting...%f"
# Caution: this setting can cause issues with multiline prompts in zsh < 5.7.1 (see #5765)
# COMPLETION_WAITING_DOTS="true"

# Uncomment the following line if you want to disable marking untracked files
# under VCS as dirty. This makes repository status check for large repositories
# much, much faster.
# DISABLE_UNTRACKED_FILES_DIRTY="true"

# Uncomment the following line if you want to change the command execution time
# stamp shown in the history command output.
# You can set one of the optional three formats:
# "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd"
# or set a custom format using the strftime function format specifications,
# see 'man strftime' for details.
# HIST_STAMPS="mm/dd/yyyy"

# Would you like to use another custom folder than $ZSH/custom?
# ZSH_CUSTOM=/path/to/new-custom-folder

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
plugins=(git asdf kubectl)

source $ZSH/oh-my-zsh.sh

# User configuration

# export MANPATH="/usr/local/man:$MANPATH"

# You may need to manually set your language environment
# export LANG=en_US.UTF-8

# Preferred editor for local and remote sessions
# if [[ -n $SSH_CONNECTION ]]; then
#   export EDITOR='vim'
# else
#   export EDITOR='mvim'
# fi

# Compilation flags
# export ARCHFLAGS="-arch x86_64"

# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

# ASDF
. "$HOME/.asdf/asdf.sh"
fpath=($HOME/.asdf/completions $fpath)
autoload -Uz compinit && compinit

alias clip="xclip -selection clipboard"
alias webstorm="nohup /opt/WebStorm-243.25659.40/bin/webstorm . >/dev/null 2>&1 &"
# alias webstorm="nohup /opt/WebStorm-243.25659.40/bin/webstorm.sh . >/dev/null 2>&1 &"
alias start-dockerd="systemctl --user start docker-desktop"
alias docker-compose="echo 'use docker compose instead of docker-compose'"
alias postman="nohup /opt/Postman/Postman . >/dev/null 2>&1 &"
# alias pycharm="nohup /opt/pycharm-community-2023.1.4/bin/pycharm.sh . >/dev/null 2>&1 &"
alias gdsbs="git config --global delta.side-by-side"
# alias dlv="~/go/bin/dlv"
# alias for find case sensitive : find . -type f -exec grep -l "qwe" {} +
# alias prism="/home/pasha/repos/heypros/hey-pros-api/node_modules/.bin/prism"
alias pp="npx pino-pretty -l -t "SYS:HH:MM:ss""
# alias pp='while IFS= read -r line; do echo "$line" | jq . 2>/dev/null || echo "$line"; done'

# alias kpn="kubectl config view --minify | grep namespace | awk -F' ' '{print $2}'"
alias set-qa="git branch -f qa HEAD && git push origin --delete qa && git push origin qa"

# set default text editor to vim
export VISUAL=vim
export EDITOR="$VISUAL"
# export PATH=$PATH:/usr/local/go/bin[[ $commands[kubectl] ]] && source <(kubectl completion zsh)
export PATH="/opt/fluent-bit/bin:$PATH"
export PATH="$PATH:/usr/local/go/bin"

autoload -Uz add-zsh-hook

_kitty_precmd_title() {
  [[ "$TERM" == "xterm-kitty" ]] || return
  local short_dir=${(%):-%1~}
  printf '\e]1;%s\a' "$short_dir"
  printf '\e]2;%s\a' "$PWD"
}

_kitty_preexec_title() {
  [[ "$TERM" == "xterm-kitty" ]] || return
  local cmd=${1%%$'\n'*}
  cmd=${cmd[1,80]}
  printf '\e]2;%s\a' "$cmd"
}

add-zsh-hook precmd _kitty_precmd_title
add-zsh-hook preexec _kitty_preexec_title

# codex installed via npm, npm installed via asdf, so this alias is to bypass shims and ignore asdf tool versions.
alias codexg='/home/pasha/.asdf/installs/nodejs/20.8.0/bin/codex'

kn() {
  if [ "$#" -eq 0 ]; then
    kubectl config view --minify | grep current-context
    kubectl config view --minify | grep namespace 
    echo "Usage: kn <namespace> [<cluster>]"
    echo "Please provide the namespace (production, staging, qa, qa-staging)."
    return 1
  elif [ "$#" -eq 2 ]; then
    NAMESPACE="$1"
    CLUSTER="$2"
    case $1 in
      production|staging|qa|qa-staging|review)
        ;;
      *)
        echo "Invalid namespace. Please choose from: production, staging, qa, qa-staging, review."
        return 1
        ;;
    esac
    echo "doctl --context ${CLUSTER} kubernetes cluster kubeconfig save ${CLUSTER}"
    echo ""
    doctl --context "$2" kubernetes cluster kubeconfig save "$2"
    echo ""
    echo "kubectl config set-context --current --namespace ${CLUSTER}-${NAMESPACE}"
    echo ""
    kubectl config set-context --current --namespace "${CLUSTER}-${NAMESPACE}"
    return 1
  elif [ "$#" -eq 1 ]; then
    NAMESPACE="$1"
    # case $1 in
    #   production|staging|qa|qa-staging)
    #     ;;
    #   *)
    #     echo "Invalid namespace. Please choose from: production, staging, qa, qa-staging."
    #     return 1
    #     ;;
    # esac
    echo "kubectl config set-context --current --namespace ${NAMESPACE}"
    echo ""
    kubectl config set-context --current --namespace "${NAMESPACE}"
    return 1
  else
    echo "Invalid number of arguments"
  fi
}

kn-seal() {
  if [ -z "$1" ]; then
    echo "no args"
    return 1
  fi
  echo -n "$1" | kubeseal --controller-name=sealed-secrets --controller-namespace=sealed-secrets --scope cluster-wide --raw | clip
}

fin-secrets-name() {
  kubectl get secret --no-headers -o custom-columns=":metadata.name" | grep ^finance-platform-api
}

# Function to get a specific key from the finance-platform-api secret
fin-secret-decode() {
  local secret_name secret_key secret_value

  # Get the secret name using fin-secrets-name
  secret_name=$(fin-secrets-name)
  if [[ -z "$secret_name" ]]; then
    echo "Error: Could not find finance-platform-api secret." >&2
    return 1
  fi

  # Get the secretKey from the argument
  secret_key=$1
  if [[ -z "$secret_key" ]]; then
    echo "Error: No secretKey argument provided. Usage: fin-get-secret-key <secretKey>" >&2
    return 1
  fi

  # Fetch the secret value for the provided key
  secret_value=$(kubectl get secret "$secret_name" -o json | jq -r ".data[\"$secret_key\"]")
  if [[ "$secret_value" == "null" || -z "$secret_value" ]]; then
    echo "Error: Key '$secret_key' not found in secret '$secret_name'." >&2
    return 1
  fi

  # Decode the base64 value
  echo "$secret_value" | base64 --decode
  echo
}


hp-v() {
  API_URL=$(k get configmap hey-pros -o json | jq .data.API_URL -r)
  echo $API_URL
  curl $API_URL
}

fin-id() {
  if [ -z "$1" ]; then
    echo "no args"
    return 1
  fi
  curl https://finance-platform-api.birdsdontexist.com/debug/hashid/"$1" | jq .id -r | clip
}

fin-hashid() {
  if [ -z "$1" ]; then
    echo "no args"
    return 1
  fi
  curl https://finance-platform-api.birdsdontexist.com/debug/id/"$1" | jq .hashid -r | clip
}

fin-reupload() {
  if [ -z "$1" ]; then
    echo "reupload no args"
    return 1
  fi
  
  # Get the hash ID
  hashid=$(curl -s https://finance-platform-api.birdsdontexist.com/debug/id/"$1" | jq -r .hashid)
  
  # Check if hashid is empty
  if [ -z "$hashid" ]; then
    echo "Failed to get hash ID"
    return 1
  fi
  
  # Reupload using the hash ID
  response=$(curl -s https://finance-platform-api.birdsdontexist.com/debug/pave/cKZ1M8erKUjx6y5srVqPacCLY/transactionsUpload/"$hashid")
  
  # Output the response
  echo "$response"
}

fin-reupload-hash() {
  if [ -z "$1" ]; then
    echo "reupload no args"
    return 1
  fi
  
  # Reupload using the hash ID
  response=$(curl -s https://finance-platform-api.birdsdontexist.com/debug/pave/cKZ1M8erKUjx6y5srVqPacCLY/transactionsUpload/"$1")
  
  # Output the response
  echo "$response"
}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
export PATH="$HOME/.local/bin:$PATH"
